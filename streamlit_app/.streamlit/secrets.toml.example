# Copy this file to secrets.toml ONLY if you are running against a
# private S3 bucket. The default deployment uses anonymous read against
# a public-read bucket policy and needs no secrets at all.
#
# secrets.toml is gitignored — never commit real keys.
# On Streamlit Community Cloud, paste these values into the app's
# Settings -> Secrets dashboard instead of using a file.

[aws]
access_key_id = "AKIA..."
secret_access_key = "..."
bucket = "hubbard-gpu-price-data"
prefix = "prices"
region = "us-east-1"
